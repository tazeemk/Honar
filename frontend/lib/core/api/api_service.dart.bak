import 'package:dio/dio.dart';
import '../storage/token_storage.dart';

class ApiService {
  static final ApiService _instance = ApiService._internal();

  late Dio dio;

  factory ApiService() {
    return _instance;
  }

  ApiService._internal() {
    dio = Dio(
      BaseOptions(
        baseUrl: "http://192.168.1.39:5000/api",
        headers: {"Content-Type": "application/json"},
        connectTimeout: const Duration(seconds: 15),
        receiveTimeout: const Duration(seconds: 15),
      ),
    );

    // Add interceptor to inject token in every request
    dio.interceptors.add(
      InterceptorsWrapper(
        onRequest: (options, handler) async {
          final token = await TokenStorage.getAccessToken();
          if (token != null && token.isNotEmpty) {
            options.headers['Authorization'] = 'Bearer $token';
            print('✅ Token injected: ${token.substring(0, 20)}...');
          } else {
            print('⚠️  No token found for request to ${options.path}');
          }
          return handler.next(options);
        },
        onError: (error, handler) async {
          print(
            '❌ API Error: ${error.response?.statusCode} - ${error.message}',
          );
          if (error.response?.statusCode == 401) {
            // Token expired, try to refresh
            try {
              // Ensure we only retry once to prevent infinite loops
              await refreshAccessToken();
              // Retry the original request
              return handler.resolve(await _retryRequest(error.requestOptions));
            } catch (e) {
              // Refresh failed, clear tokens and return error
              await TokenStorage.clearTokens();
              return handler.next(error);
            }
          }
          return handler.next(error);
        },
      ),
    );
  }

  Future<Response> _retryRequest(RequestOptions requestOptions) async {
    final options = Options(
      method: requestOptions.method,
      headers: requestOptions.headers,
    );
    return dio.request<dynamic>(
      requestOptions.path,
      data: requestOptions.data,
      queryParameters: requestOptions.queryParameters,
      options: options,
    );
  }

  Future<void> refreshAccessToken() async {
    final refreshToken = await TokenStorage.getRefreshToken();
    if (refreshToken == null || refreshToken.isEmpty) {
      await TokenStorage.clearTokens();
      throw Exception('No refresh token available. Please log in again.');
    }

    try {
      // Make a direct request without interceptors to avoid infinite loops
      // if the refresh token itself is expired or invalid.
      final response = await Dio(
        BaseOptions(
          baseUrl: dio.options.baseUrl,
          headers: {"Content-Type": "application/json"},
        ),
      ).post("/auth/refresh", data: {"refreshToken": refreshToken});

      final newAccessToken = response.data['accessToken'];
      final newRefreshToken = response.data['refreshToken'];
      final user = response.data['user'];

      if (newAccessToken != null && newRefreshToken != null && user != null) {
        await TokenStorage.saveTokens(
          accessToken: newAccessToken,
          refreshToken: newRefreshToken,
          userId: user['id'].toString(),
          userRole: user['role'],
          userEmail: user['email'],
        );
      } else {
        throw Exception('Failed to get new tokens from refresh endpoint.');
      }
    } catch (e) {
      await TokenStorage.clearTokens();
      rethrow;
    }
  }

  Future<dynamic> register(String email, String password, String role) async {
    try {
      final response = await dio.post(
        "/auth/register",
        data: {"email": email, "password": password, "role": role},
      );

      // Save tokens
      if (response.statusCode == 201) {
        final data = response.data;

        // Handle both int and string IDs from backend
        String userId = '';
        if (data['user'] != null && data['user']['id'] != null) {
          userId = data['user']['id'].toString();
        }

        String userRole = data['user']['role']?.toString() ?? 'worker';
        String userEmail = data['user']['email']?.toString() ?? email;
        String accessToken = data['accessToken']?.toString() ?? '';
        String refreshToken = data['refreshToken']?.toString() ?? '';

        if (userId.isNotEmpty && accessToken.isNotEmpty) {
          await TokenStorage.saveTokens(
            accessToken: accessToken,
            refreshToken: refreshToken,
            userId: userId,
            userRole: userRole,
            userEmail: userEmail,
          );
        }
        return data;
      }
      return response.data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<dynamic> login(String email, String password) async {
    try {
      final response = await dio.post(
        "/auth/login",
        data: {"email": email, "password": password},
      );

      // Save tokens with proper null checking
      final data = response.data;

      // Handle both int and string IDs from backend
      String userId = '';
      if (data['user'] != null && data['user']['id'] != null) {
        userId = data['user']['id'].toString();
      }

      String userRole = data['user']?['role']?.toString() ?? 'worker';
      String userEmail = data['user']?['email']?.toString() ?? email;
      String accessToken = data['accessToken']?.toString() ?? '';
      String refreshToken = data['refreshToken']?.toString() ?? '';

      if (userId.isNotEmpty && accessToken.isNotEmpty) {
        await TokenStorage.saveTokens(
          accessToken: accessToken,
          refreshToken: refreshToken,
          userId: userId,
          userRole: userRole,
          userEmail: userEmail,
        );
      }

      return data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<dynamic> completeProfile(Map<String, dynamic> data) async {
    try {
      final response = await dio.put("/profile/complete", data: data);
      return response.data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<dynamic> completeClientProfile(Map<String, dynamic> data) async {
    try {
      final response = await dio.put("/client/complete", data: data);
      return response.data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<dynamic> subscribe() async {
    try {
      final response = await dio.put("/profile/subscribe");
      return response.data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<dynamic> subscribeClient() async {
    try {
      final response = await dio.put("/client/subscribe");
      return response.data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<dynamic> getWorkers() async {
    try {
      final response = await dio.get("/worker");
      return response.data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<dynamic> getMyProfile() async {
    try {
      final response = await dio.get("/profile/me");
      return response.data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  // ── Favorites ──────────────────────────────────────────

  Future<Map<String, dynamic>> toggleFavorite(int workerProfileId) async {
    try {
      final response = await dio.post("/favorites/toggle/$workerProfileId");
      return response.data as Map<String, dynamic>;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<bool> checkFavorite(int workerProfileId) async {
    try {
      final response = await dio.get("/favorites/check/$workerProfileId");
      return (response.data['isFavorite'] as bool?) ?? false;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<List<dynamic>> getMyFavorites() async {
    try {
      final response = await dio.get("/favorites");
      return response.data as List<dynamic>;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<dynamic> uploadId(String file) async {
    try {
      final response = await dio.put(
        "/profile/upload-id",
        data: {"idProof": file},
      );
      return response.data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  Future<dynamic> uploadIdClient(String file) async {
    try {
      final response = await dio.put(
        "/client/upload-id",
        data: {"idProof": file},
      );
      return response.data;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  // ── Admin Dashboard ───────────────────────────────────────────────
  Future<Map<String, dynamic>> getAdminDashboard() async {
    try {
      final response = await dio.get('/admin/dashboard');
      return response.data as Map<String, dynamic>;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  // ── Approve Verification ──────────────────────────────────────────
  Future<void> approveVerification(int id) async {
    try {
      await dio.post('/admin/verify/$id/approve');
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  // ── Reject Verification ───────────────────────────────────────────
  Future<void> rejectVerification(int id) async {
    try {
      await dio.post('/admin/verify/$id/reject');
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  // ── All Users ─────────────────────────────────────────────────────
  Future<Map<String, dynamic>> getAdminUsers({
    String? role,
    int page = 1,
  }) async {
    try {
      final response = await dio.get(
        '/admin/users',
        queryParameters: {if (role != null) 'role': role, 'page': page},
      );
      return response.data as Map<String, dynamic>;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  // ── All Disputes ──────────────────────────────────────────────────
  Future<List<dynamic>> getAdminDisputes() async {
    try {
      final response = await dio.get('/admin/disputes');
      return response.data as List<dynamic>;
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  // ── Resolve Dispute ───────────────────────────────────────────────
  Future<void> resolveDispute(int id, String resolution) async {
    try {
      await dio.put(
        '/admin/disputes/$id/resolve',
        data: {'resolution': resolution},
      );
    } on DioException catch (e) {
      throw _handleDioError(e);
    }
  }

  String _handleDioError(DioException error) {
    if (error.type == DioExceptionType.connectionTimeout) {
      return 'Connection timeout. Please check your network.';
    } else if (error.type == DioExceptionType.receiveTimeout) {
      return 'Server timeout. Please try again.';
    } else if (error.response != null) {
      final statusCode = error.response?.statusCode;
      final message = error.response?.data['message'] ?? 'An error occurred';

      if (statusCode == 401) {
        return 'Unauthorized. Please login again.';
      } else if (statusCode == 403) {
        return 'Forbidden. You do not have permission.';
      } else if (statusCode == 400) {
        return message;
      } else if (statusCode == 500) {
        return 'Server error. Please try again later.';
      }
      return message;
    } else if (error.message?.contains('XMLHttpRequest') ?? false) {
      return 'Network error. Please check your connection.';
    } else {
      return error.message ?? 'An unexpected error occurred';
    }
  }
}
